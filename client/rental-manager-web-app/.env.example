# Real .NET API URL. Used when mock mode is disabled or for unmocked endpoints.
VITE_API_URL=http://localhost:5008

# Optional BFF URL. Defaults to VITE_API_URL when omitted.
VITE_BFF_URL=http://localhost:5008

# Development defaults to true when this variable is omitted.
# Set false to call the real backend for Property and Room APIs.
VITE_ENABLE_MOCK_API=true

# Simulated network latency in milliseconds.
VITE_MOCK_API_DELAY=250
